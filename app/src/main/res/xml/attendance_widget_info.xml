<?xml version="1.0" encoding="utf-8"?>
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"

    android:label="@string/attendance_widget_name"
    android:description="@string/attendance_widget_description"

    android:minWidth="140dp"
    android:minHeight="80dp"
    android:minResizeWidth="140dp"
    android:minResizeHeight="80dp"

    android:targetCellWidth="3"
    android:targetCellHeight="2"

    android:maxResizeWidth="400dp"
    android:maxResizeHeight="300dp"

    android:updatePeriodMillis="7200000"

    android:previewImage="@drawable/widget_attendance_preview"
