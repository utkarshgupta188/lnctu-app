<?xml version="1.0" encoding="utf-8"?>
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"

    android:label="@string/timetable_widget_name"
    android:description="@string/timetable_widget_description"

    android:minWidth="180dp"
    android:minHeight="220dp"
    android:minResizeWidth="120dp"
    android:minResizeHeight="180dp"

    android:targetCellWidth="3"
    android:targetCellHeight="4"

    android:maxResizeWidth="600dp"
    android:maxResizeHeight="500dp"

    android:updatePeriodMillis="3600000"

    android:previewImage="@drawable/widget_timetable_preview"
    android:previewLayout="@layout/widget_timetable_preview"

    android:initialLayout="@layout/glance_default_loading_layout"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
