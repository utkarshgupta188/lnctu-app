<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A27"
    android:padding="10dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Today  •  Monday"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textColor="#6C63FF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Period 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:background="#22223A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:layout_width="38dp" android:layout_height="wrap_content"
            android:text="09:00" android:textColor="#6C63FF" android:textSize="10sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Data Visualization" android:textColor="#FFFFFF" android:textSize="11sp" android:singleLine="true"/>
    </LinearLayout>

    <!-- Period 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="3dp"
        android:background="#22223A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:layout_width="38dp" android:layout_height="wrap_content"
            android:text="09:45" android:textColor="#6C63FF" android:textSize="10sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Web Technology" android:textColor="#FFFFFF" android:textSize="11sp" android:singleLine="true"/>
    </LinearLayout>

    <!-- Period 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="3dp"
        android:background="#22223A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:layout_width="38dp" android:layout_height="wrap_content"
            android:text="10:30" android:textColor="#6C63FF" android:textSize="10sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Software Engineering" android:textColor="#FFFFFF" android:textSize="11sp" android:singleLine="true"/>
    </LinearLayout>

    <!-- Period 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="3dp"
        android:background="#22223A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:layout_width="38dp" android:layout_height="wrap_content"
            android:text="11:15" android:textColor="#6C63FF" android:textSize="10sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Lunch Break" android:textColor="#FFC107" android:textSize="11sp" android:singleLine="true"/>
    </LinearLayout>

    <!-- Period 5 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="3dp"
        android:background="#22223A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:layout_width="38dp" android:layout_height="wrap_content"
            android:text="12:15" android:textColor="#6C63FF" android:textSize="10sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Computer Networks" android:textColor="#FFFFFF" android:textSize="11sp" android:singleLine="true"/>
    </LinearLayout>

    <!-- Period 6 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="3dp"
        android:background="#22223A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:layout_width="38dp" android:layout_height="wrap_content"
            android:text="13:00" android:textColor="#6C63FF" android:textSize="10sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Web Technology-T" android:textColor="#FFFFFF" android:textSize="11sp" android:singleLine="true"/>
    </LinearLayout>

    <!-- Period 7 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="3dp"
        android:background="#22223A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:layout_width="38dp" android:layout_height="wrap_content"
            android:text="13:45" android:textColor="#6C63FF" android:textSize="10sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Software Engg.-P" android:textColor="#4CAF50" android:textSize="11sp" android:singleLine="true"/>
    </LinearLayout>

</LinearLayout>
