<?xml version="1.0" encoding="utf-8"?>
<!--
    LNCT Attendance app icon foreground.
    Design: Graduation cap on top, bar-chart below — represents
    academic attendance tracking at LNCT University.
    All paths are centred in the 108×108 safe-zone (72×72 inner area, offset 18,18).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Graduation cap base (mortarboard) ── -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,22 L78,34 L54,46 L30,34 Z" />

    <!-- Cap top knob -->
    <path
        android:fillColor="#6C63FF"
        android:pathData="M54,22 L54,17 Q56,19 54,22 Z" />

    <!-- Left tassel string -->
    <path
        android:strokeColor="#6C63FF"
        android:strokeWidth="2.5"
        android:fillColor="#00000000"
        android:pathData="M30,34 L30,44 Q28,50 33,52" />

    <!-- Tassel end -->
    <path
        android:fillColor="#6C63FF"
        android:pathData="M30,44 Q26,50 30,54 Q34,50 30,44 Z" />

    <!-- Cap band shadow -->
    <path
        android:fillColor="#22000000"
        android:pathData="M54,46 L78,34 L78,36 L54,48 Z" />

    <!-- ── Bar chart (4 bars) below cap ── -->

    <!-- Bar 1 — left (red) -->
    <path
        android:fillColor="#E53935"
        android:pathData="M33,86 L33,72 L41,72 L41,86 Z" />

    <!-- Bar 2 — center-left (amber) -->
    <path
        android:fillColor="#FFC107"
        android:pathData="M46,86 L46,64 L54,64 L54,86 Z" />

    <!-- Bar 3 — center-right (green) -->
    <path
        android:fillColor="#4CAF50"
        android:pathData="M59,86 L59,55 L67,55 L67,86 Z" />

    <!-- Bar 4 — right (purple) -->
    <path
        android:fillColor="#6C63FF"
        android:pathData="M72,86 L72,60 L80,60 L80,86 Z" />

    <!-- Chart baseline -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:pathData="M28,86 L84,86" />

</vector>
